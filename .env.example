# =============================================================================
# AI Influencer Live Stream — Environment Variables
# =============================================================================
# Copy this file to .env and fill in real values before running the Python
# stream engine or generate_avatar.py.
#
#   cp .env.example .env
#   # edit .env with your keys
#   source .env   # or use: python-dotenv, direnv, etc.
#
# The Node.js server has its own env file at server/.env.example
# =============================================================================

# -----------------------------------------------------------------------------
# REQUIRED — AI brain (Claude)
# Get your key at: https://console.anthropic.com/account/keys
# -----------------------------------------------------------------------------
ANTHROPIC_API_KEY=sk-ant-...

# -----------------------------------------------------------------------------
# TTS — pick at least one
# -----------------------------------------------------------------------------

# ElevenLabs (best quality, voice cloning)
# https://elevenlabs.io → Profile → API Key
ELEVENLABS_API_KEY=

# -----------------------------------------------------------------------------
# Chat readers
# -----------------------------------------------------------------------------

# YouTube Data API v3 (for YouTube Live Chat)
# https://console.cloud.google.com → APIs → YouTube Data API v3
YOUTUBE_API_KEY=

# Twitch channel name is passed via --twitch flag (no key required for
# anonymous read-only IRC).

# -----------------------------------------------------------------------------
# Avatar generation (generate_avatar.py) — pick one image provider
# -----------------------------------------------------------------------------

# Together AI — fast & cheap, recommended
# https://api.together.xyz/settings/api-keys
TOGETHER_API_KEY=

# Replicate — alternative image provider
# https://replicate.com/account/api-tokens
REPLICATE_API_TOKEN=

# OpenAI DALL-E 3 — alternative image provider
# https://platform.openai.com/api-keys
OPENAI_API_KEY=

# -----------------------------------------------------------------------------
# Supabase bridge — connects Python engine to the Railway Node.js backend
# Set this to the WebSocket URL of your deployed Railway service.
# Local dev: ws://localhost:3000/ws
# Production: ws://your-service.railway.app/ws
# -----------------------------------------------------------------------------
SUPABASE_BRIDGE_URL=ws://localhost:3000/ws
